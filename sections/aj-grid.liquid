{% comment %}
  Section: aj-grid
  Part 2 of 2 — Six-product grid with quick-view popup for the Gift Guide page.

  Features:
    • 6 blocks, each linked to a Shopify product via the customizer
    • Each card shows the product image with a "+" button
    • Clicking "+" opens a popup showing name, price, description, colour
      swatches and size dropdown — all rendered dynamically from product JSON
    • "ADD TO CART" posts to /cart/add.js (Ajax — no page reload)
    • Auto-adds "Soft Winter Jacket" when Color=Black AND Size=Medium is chosen
    • Section title editable from customizer
    • Fully responsive (3-column desktop → 2-column mobile)

  Design reference: Figma node 1:1662 (desktop) + 1:1946 (mobile)
  Popup reference:  Figma node 43:351
{% endcomment %}

{%- comment -%} Google Fonts — idempotent, safe to include in multiple sections {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&family=Lustria&display=swap"
  rel="stylesheet"
>

{{ 'aj-grid.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Pass Liquid settings to JavaScript via a global config object.
  The popup JS reads this before the section renders, so it must come first.
{%- endcomment -%}
<script>
  window.AJGridConfig = {
    softWinterJacketHandle: {{ section.settings.soft_winter_jacket_handle | json }}
  };
</script>

<script src="{{ 'aj-popup.js' | asset_url }}" defer></script>

{%- comment -%}━━━━━━━━━━━━━━━━━━━ GRID SECTION ━━━━━━━━━━━━━━━━━━{%- endcomment -%}
<section
  class="aj-grid"
  id="aj-grid-{{ section.id }}"
>
  <div class="aj-grid__inner">

    {%- comment -%} Section title — editable from customizer {%- endcomment -%}
    {%- if section.settings.section_title != blank -%}
      <h2 class="aj-grid__title">{{ section.settings.section_title }}</h2>
    {%- endif -%}

    {%- comment -%} Product grid — up to 6 blocks {%- endcomment -%}
    <div class="aj-grid__products" role="list">

      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}

        <div
          class="aj-grid__item"
          role="listitem"
          {{ block.shopify_attributes }}
        >
          <div class="aj-grid__card">
            <div class="aj-grid__img-wrap">

              {%- if product != blank -%}
                {%- comment -%} Product image {%- endcomment -%}
                {{
                  product.featured_image
                  | image_url: width: 600
                  | image_tag:
                    class: 'aj-grid__img',
                    loading: 'lazy',
                    sizes: '(max-width: 749px) 50vw, 33vw',
                    widths: '300, 450, 600',
                    alt: product.title | escape
                }}

                {%- comment -%}
                  Quick-view trigger button.
                  data-product-handle is consumed by aj-popup.js to fetch
                  product data on demand — no preloaded JSON needed.
                {%- endcomment -%}
                {%- comment -%}
                  Plus button — position driven by per-block customizer settings.
                  top / left are percentages (0–100) relative to the card image.
                  Defaults to 50 / 50 (centre) if not set.
                {%- endcomment -%}
                <button
                  class="aj-grid__plus-btn"
                  type="button"
                  data-product-handle="{{ product.handle }}"
                  aria-label="Quick view {{ product.title | escape }}"
                  style="top:{{ block.settings.btn_top }}%;left:{{ block.settings.btn_left }}%;transform:translate(-50%,-50%);"
                >
                  <span class="aj-grid__plus-icon" aria-hidden="true">+</span>
                </button>

              {%- else -%}
                {%- comment -%} Empty block — show placeholder in theme editor {%- endcomment -%}
                {{ 'product-apparel-1' | placeholder_svg_tag: 'aj-grid__img aj-grid__img--placeholder' }}

              {%- endif -%}

            </div>
          </div>
        </div>

      {%- endfor -%}

    </div>

  </div>
</section>

{%- comment -%}━━━━━━━━━━━━━━━━━━━ POPUP ━━━━━━━━━━━━━━━━━━━━━━━━{%- endcomment -%}
{%- comment -%}
  Rendered once per page load; controlled entirely by aj-popup.js.
  Position: fixed, so placement inside the section DOM has no visual impact.
{%- endcomment -%}
<div
  class="aj-popup-overlay"
  id="aj-popup-overlay"
  aria-hidden="true"
  aria-modal="true"
  role="dialog"
  aria-labelledby="aj-popup-title"
>
  <div class="aj-popup">

    {%- comment -%} Close × button — top-right corner {%- endcomment -%}
    <button
      class="aj-popup__close"
      id="aj-popup-close"
      type="button"
      aria-label="{{ 'accessibility.close' | t }}"
    >&times;</button>

    {%- comment -%}
      Content container — populated dynamically by renderPopup() in aj-popup.js.
      Structure injected at runtime:
        .aj-popup__body      — product image + name / price / description
        .aj-popup__variant-group (×2) — colour swatches + size dropdown
        .aj-popup__footer    — ADD TO CART button
    {%- endcomment -%}
    <div class="aj-popup__content" id="aj-popup-content"></div>

  </div>
</div>

{% schema %}
{
  "name": "AJ Product Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "text",
      "id": "soft_winter_jacket_handle",
      "label": "Soft Winter Jacket — Product Handle",
      "default": "soft-winter-jacket",
      "info": "Product handle for the item auto-added when a Black + Medium variant is purchased."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "header",
          "content": "+ Button Position"
        },
        {
          "type": "range",
          "id": "btn_top",
          "label": "Top (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "info": "Vertical position of the + button as a percentage of the card height"
        },
        {
          "type": "range",
          "id": "btn_left",
          "label": "Left (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50,
          "info": "Horizontal position of the + button as a percentage of the card width"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "AJ Product Grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
